} from '~/constants/socials';
import DefaultLayout from '~/layouts/DefaultLayout.astro';

const programmingAndConsultingYears = new Date().getFullYear() - 2015;
const fullStackExperienceYears = new Date().getFullYear() - 2018;
const awsExperienceYears = new Date().getFullYear() - 2020;

type Timeframe = {
	start: Date;
	end?: Date;
};

const now = new Date();

function getInclusiveMonthCount({ start, end }: Timeframe) {
	const effectiveEnd = end ?? now;

	return (effectiveEnd.getUTCFullYear() - start.getUTCFullYear()) * 12 + effectiveEnd.getUTCMonth() - start.getUTCMonth() + 1;
}

function getLatestStartDate(timeframes: Timeframe[]) {
	return new Date(Math.max(...timeframes.map((timeframe) => timeframe.start.getTime())));
}

function formatClientProjectDate(timeframes: Timeframe[]) {
	const totalMonths = timeframes.reduce((sum, timeframe) => sum + getInclusiveMonthCount(timeframe), 0);
	const startYear = Math.min(...timeframes.map((timeframe) => timeframe.start.getUTCFullYear()));

	return `${startYear} - ${totalMonths} ${totalMonths === 1 ? 'month' : 'months'}`;
}

const clientProjects = (await getCollection('clientProjects'))
	.toSorted((a, b) => getLatestStartDate(b.data.timeframes).getTime() - getLatestStartDate(a.data.timeframes).getTime())
	.map((project) => ({
		...project,
		dateLabel: formatClientProjectDate(project.data.timeframes),
	}));
