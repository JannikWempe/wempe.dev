---
import BlogPostCard from '../../../components/BlogPostCard.astro';
import DefaultLayout from '~/layouts/DefaultLayout.astro';
import { createBlogReadModel, type BlogTeaser } from '~/lib/blog';
import type { GetStaticPaths } from 'astro';
import BlogIndexJsonLd from '~/components/BlogIndexJsonLd.astro';

export const prerender = true;

const blog = createBlogReadModel();

export const getStaticPaths = (async () => {
	const { tagParams } = await createBlogReadModel().catalog();

	return tagParams.map(({ slug }) => ({
		params: { slug },
		props: { tag: slug },
	}));
}) satisfies GetStaticPaths;

const { tag } = Astro.props;
const { items: posts, total } = await blog.list({ kind: 'tag', tag });

const tagDescriptions: Record<string, string> = {
	nextjs: 'Explore Next.js tutorials, server components, app router patterns, and performance optimization tips. Learn modern React development with real-world examples.',
	auth: 'Discover authentication and authorization patterns, OAuth flows, JWT handling, and security best practices. Implement secure user login in your web applications.',
	ai: 'Read about artificial intelligence, machine learning integration, LLMs, and AI-powered development. Practical guides for building intelligent applications.',
	ddd: 'Learn Domain-Driven Design concepts including entities, value objects, aggregates, and bounded contexts. Apply tactical DDD patterns in TypeScript projects.',
	shopify: 'Shopify app development guides covering billing, webhooks, API integration, and best practices. Build and scale successful Shopify apps.',
};

const getDescription = (tagg: string, count: number) => {
	if (tagDescriptions[tagg]) return tagDescriptions[tagg];
	return `Explore ${count} articles about ${tagg} covering tutorials, best practices, and real-world implementation patterns for modern software development.`;
};

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Blog', href: '/blog' },
	{ label: `#${tag}`, href: `/blog/tag/${tag}`, current: true },
];
---

<DefaultLayout
	metadata={{
		title: `${tag} Posts | Jannik Wempe`,
		description: getDescription(tag, total),
	}}
	{breadcrumbItems}
>
	<Fragment slot="header">
		<BlogIndexJsonLd posts={posts.slice(0, 5)} {breadcrumbItems} />
	</Fragment>
	<div class="container mx-auto">
		<h1 class="text-3xl font-bold text-slate-900">
			{total}
			#{tag}
			{total === 1 ? 'Post' : 'Posts'}
		</h1>

		<div class="mt-5 grid grid-cols-1 gap-12 md:grid-cols-2">
			{posts.map((post, index) => <BlogPostCard post={post} imageProps={{ loading: index <= 3 ? 'eager' : 'lazy' }} />)}
		</div>
	</div>
</DefaultLayout>
