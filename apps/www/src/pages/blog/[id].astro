---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Prose from '~/components/Prose.astro';
import BlogPostLayout from '~/layouts/BlogPostLayout.astro';
import { formatDate } from '~/utils/time';
import type { GetStaticPaths } from 'astro';
import BlogPostJsonLd from '~/components/BlogPostJsonLd.astro';
import Badge from '~/components/ui/Badge.astro';
import { createBlogReadModel } from '~/lib/blog';

export const prerender = true;

export const getStaticPaths = (async () => {
	const blog = createBlogReadModel();
	const catalog = await blog.catalog();
	return catalog.postParams.map((p) => ({
		params: { id: p.slug },
	}));
}) satisfies GetStaticPaths;

const blog = createBlogReadModel();
const postPage = await blog.post({ slug: Astro.params.id! });

if (!postPage) {
	return Astro.redirect('/blog');
}

const formattedDatePublished = formatDate(postPage.publishedAt);

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Blog', href: '/blog' },
	{ label: postPage.title, href: postPage.url, current: true },
];

const Content = postPage.content as any;
---

<BlogPostLayout postPage={postPage} {breadcrumbItems}>
	<Fragment slot="header">
		<BlogPostJsonLd {postPage} {breadcrumbItems} />
		<Image
			transition:name={`cover-${postPage.slug}`}
			src={postPage.cover as ImageMetadata}
			alt={postPage.title}
			width={(postPage.cover as ImageMetadata).width / 2}
			height={(postPage.cover as ImageMetadata).height / 2}
			loading="eager"
			fetchpriority="high"
			format={(postPage.cover as ImageMetadata).format !== 'gif' ? 'avif' : 'gif'}
			class="mb-6 rounded-2xl shadow-lg"
		/>

		<h1 transition:name={`title-${postPage.slug}`} class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{postPage.title}</h1>
		{postPage.subtitle && <h2 class="mt-3 text-lg text-slate-600 leading-relaxed">{postPage.subtitle}</h2>}

		{
			postPage.tags.length > 0 && (
				<div class="mt-3 flex flex-wrap gap-2">
					{postPage.tags.map((tag: string) => (
						<Badge
							as="a"
							href={`/blog/tag/${tag}`}
							variant="slate"
							class="transition-colors hover:bg-indigo-50 hover:text-indigo-700 hover:ring-indigo-600/10"
						>
							{tag}
						</Badge>
					))}
				</div>
			)
		}

		<div class="mt-3 flex items-center gap-5">
			<div class="flex items-center gap-1">
				<Icon name="lucide:calendar" class="text-slate-500" />
				<time class="block text-sm font-semibold text-slate-500">
					{formattedDatePublished}
				</time>
			</div>
			<div class="flex items-center gap-1">
				<Icon name="lucide:clock" class="text-slate-500" />
				<span class="text-sm font-semibold text-slate-500">{postPage.readingTime.text}</span>
			</div>
		</div>
	</Fragment>

	<Prose id="content" class="mt-8">
		<Content />
	</Prose>
</BlogPostLayout>

<script>
	function makeHeadingsClickable() {
		const content = document.getElementById('content');
		if (!content) return;

		const headings = content.querySelectorAll('h1, h2, h3, h4, h5, h6');
		headings.forEach((heading) => {
			heading.classList.add('cursor-pointer', 'hover:text-indigo-800');

			heading.addEventListener('click', () => {
				window.location.hash = heading.id;
			});
		});
	}

	document.addEventListener('astro:page-load', makeHeadingsClickable);
</script>
