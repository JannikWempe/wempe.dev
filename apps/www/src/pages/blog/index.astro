---
import BlogPostCard from '../../components/BlogPostCard.astro';
import DefaultLayout from '~/layouts/DefaultLayout.astro';
import BlogIndexJsonLd from '~/components/BlogIndexJsonLd.astro';
import { createBlogReadModel, type BlogTeaser } from '~/lib/blog';

export const prerender = true;

const allPosts = await createBlogReadModel().list({ kind: 'all' });
const posts: BlogTeaser[] = allPosts.items;

const breadcrumbItems = [
	{ label: 'Home', href: '/' },
	{ label: 'Blog', href: '/blog', current: true },
];
---

<DefaultLayout
	metadata={{
		title: 'Blog | Jannik Wempe',
		description:
			'Articles on web development, software engineering, and tech best practices. Tutorials on TypeScript, AWS, and more.',
	}}
	{breadcrumbItems}
>
	<Fragment slot="header">
		<BlogIndexJsonLd posts={posts.slice(0, 10)} {breadcrumbItems} />
	</Fragment>
	<div class="container mx-auto">
		<h1 class="text-3xl font-bold text-slate-900">My {allPosts.total} Blog Posts</h1>
		<div class="mt-5 grid grid-cols-1 gap-12 md:grid-cols-2">
			{posts.map((post, index) => <BlogPostCard post={post} imageProps={{ loading: index <= 3 ? 'eager' : 'lazy' }} />)}
		</div>
	</div>
</DefaultLayout>
