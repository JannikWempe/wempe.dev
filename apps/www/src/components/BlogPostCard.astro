---
import { Icon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';
import { Image, type ImgAttributes } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { twMerge } from 'tailwind-merge';
import { formatDate } from '~/utils/time';
import { render } from 'astro:content';
import Badge from '~/components/ui/Badge.astro';
import Card from '~/components/ui/Card.astro';
import type { BlogTeaser } from '~/lib/blog';

interface Props extends HTMLAttributes<'article'> {
	post: CollectionEntry<'blog'> | BlogTeaser;
	imageProps?: Omit<ImgAttributes, 'src' | 'alt' | 'width' | 'height' | 'class'>;
}

const { post, class: classes, imageProps, ...rest } = Astro.props;
const isTeaser = 'url' in post;
const title = isTeaser ? post.title : post.data.title;
const excerpt = isTeaser ? post.excerpt : post.data.excerpt;
const publishedAt = isTeaser ? post.publishedAt : post.data.datePublished;
const cover = isTeaser ? post.cover : post.data.cover;
const slug = isTeaser ? post.slug : post.data.slug;
const tags = isTeaser ? post.tags : post.data.tags;
const url = isTeaser ? post.url : `/blog/${slug}`;
const formattedDate = formatDate(publishedAt);
const readingTimeText = isTeaser ? post.readingTime.text : (await render(post)).remarkPluginFrontmatter.readingTime.text;
---

<Card
	as="article"
	interactive
	focusRing="within"
	class={twMerge(
		'group overflow-hidden',
		classes
	)}
	{...rest}
>
	<a href={url} class="block overflow-hidden rounded-t-2xl">
		<Image
			transition:name={`cover-${slug}`}
			src={cover}
			alt={title}
			width={650}
			height={341}
			format={cover.format !== 'gif' ? 'avif' : 'gif'}
			class="w-full object-cover transition-transform duration-300 group-hover:scale-105"
			{...imageProps}
		/>
	</a>
	<div class="p-6">
		{
			tags && tags.length > 0 && (
				<div class="mb-3 flex flex-wrap gap-2">
					{tags.map((tag: string) => (
						<Badge
							as="a"
							href={`/blog/tag/${tag}`}
							variant="slate"
							size="sm"
							class="transition-colors hover:bg-indigo-50 hover:text-indigo-700 hover:ring-indigo-600/10"
						>
							{tag}
						</Badge>
					))}
				</div>
			)
		}
		<a href={url} class="block">
			<h2
				transition:name={`title-${slug}`}
				class="text-xl font-bold tracking-tight text-slate-900 transition-colors group-hover:text-indigo-600"
			>
				{title}
			</h2>
		</a>
		<div class="mt-2 flex items-center gap-3 text-sm text-slate-500">
			<div class="flex items-center gap-1.5">
				<Icon name="lucide:calendar" class="h-4 w-4" />
				<time datetime={formattedDate}>
					{formattedDate}
				</time>
			</div>
			<div class="flex items-center gap-1.5">
				<Icon name="lucide:clock" class="h-4 w-4" />
				<span>
					{readingTimeText}
				</span>
			</div>
		</div>
		<p class="mt-3 line-clamp-3 text-slate-600 leading-relaxed">{excerpt}</p>
	</div>
</Card>
