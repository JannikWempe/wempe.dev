---
import type { HTMLTag, Polymorphic } from 'astro/types';
import { twMerge } from 'tailwind-merge';

type Props<T extends HTMLTag = 'button'> = Polymorphic<{ as: T }> & {
	variant?: 'solid' | 'outline' | 'ghost';
	size?: 'sm' | 'md' | 'lg' | 'xl';
	color?: 'primary' | 'secondary';
};

const {
	as: Tag = 'button' as any,
	variant = 'solid',
	size = 'md',
	color = 'primary',
	class: classes = '',
	...rest
} = Astro.props;

const baseStyles =
	'inline-flex items-center justify-center rounded-md font-medium transition-colors focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50';

const variants = {
	primary: {
		solid: 'bg-brand-primary text-white hover:bg-brand-primary-hover active:bg-brand-primary-active focus-visible:ring-focus-ring',
		outline: 'border-2 border-brand-primary text-brand-primary hover:bg-brand-primary-soft active:bg-indigo-100',
		ghost: 'text-brand-primary hover:bg-brand-primary-soft active:bg-indigo-100',
	},
	secondary: {
		solid: 'bg-brand-secondary text-white hover:bg-brand-secondary-hover active:bg-brand-secondary-active focus-visible:ring-focus-ring',
		outline: 'border-2 border-brand-secondary text-brand-secondary hover:bg-brand-secondary-soft active:bg-blue-100',
		ghost: 'text-brand-secondary hover:bg-brand-secondary-soft active:bg-blue-100',
	},
};

const sizes = {
	sm: 'h-8 px-3 text-sm gap-1.5',
	md: 'h-10 px-4 text-sm gap-2',
	lg: 'h-12 px-6 text-base gap-2.5',
	xl: 'h-14 px-8 text-lg gap-3',
};
---

<Tag class={twMerge(baseStyles, variants[color][variant], sizes[size], classes)} {...rest}>
	<slot name="icon-left" />
	<slot />
	<slot name="icon-right" />
</Tag>
