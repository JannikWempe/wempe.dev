---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { twMerge } from 'tailwind-merge';
import Card from './ui/Card.astro';

export interface Props {
	previousPost?: CollectionEntry<'blog'>;
	nextPost?: CollectionEntry<'blog'>;
	class?: string;
}

const { previousPost, nextPost, class: classes } = Astro.props;
---

<nav class={twMerge('grid grid-cols-1 md:grid-cols-2 gap-4', classes)}>
	{
		previousPost ? (
			<Card
				as="a"
				interactive
				focusRing="visible"
				padding="sm"
				radius="lg"
				href={`/blog/${previousPost.id}`}
				class="group flex items-center gap-3"
			>
				<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-100 text-slate-600 transition-colors group-hover:bg-indigo-100 group-hover:text-indigo-600">
					<Icon name="lucide:arrow-left" class="h-5 w-5" />
				</div>
				<div>
					<span class="block text-xs font-medium tracking-wide text-slate-500 uppercase">Previous</span>
					<span class="line-clamp-2 font-semibold text-slate-900 transition-colors group-hover:text-indigo-600">
						{previousPost.data.title}
					</span>
				</div>
			</Card>
		) : (
			<div />
		)
	}
	{
		nextPost && (
			<Card
				as="a"
				interactive
				focusRing="visible"
				padding="sm"
				radius="lg"
				href={`/blog/${nextPost.id}`}
				class="group flex items-center gap-3 md:flex-row-reverse md:text-right"
			>
				<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-100 text-slate-600 transition-colors group-hover:bg-indigo-100 group-hover:text-indigo-600">
					<Icon name="lucide:arrow-right" class="h-5 w-5" />
				</div>
				<div>
					<span class="block text-xs font-medium tracking-wide text-slate-500 uppercase">Next</span>
					<span class="line-clamp-2 font-semibold text-slate-900 transition-colors group-hover:text-indigo-600">
						{nextPost.data.title}
					</span>
				</div>
			</Card>
		)
	}
</nav>
